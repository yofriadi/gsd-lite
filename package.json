{
  "name": "gsd-lite",
  "version": "0.1.0",
  "description": "Pi-powered planner/builder review loop with subagents runtime",
  "type": "module",
  "scripts": {
    "fix": "prettier --write '**/*.ts' && eslint '**/*.ts' --fix",
    "test": "tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && eslint '**/*.ts' && npm test && prettier --check '**/*.ts'"
  },
  "keywords": [
    "pi-package",
    "pi",
    "planner",
    "gsd"
  ],
  "license": "MIT",
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@gotgenes/pi-subagents": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@earendil-works/pi-tui": "^0.79.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.0.0",
    "typebox": "^1.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
